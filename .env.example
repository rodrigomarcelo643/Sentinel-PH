# =========================
# FIREBASE (Frontend)
# =========================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_MEASUREMENT_ID=your_measurement_id

# =========================
# BACKEND
# =========================
VITE_BACKEND_URL=http://localhost:3001

# =========================
# FIREBASE ADMIN (Backend)
# =========================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# =========================
# GOOGLE SERVICES
# =========================
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GEOAPIFY_API_KEY=your_geoapify_api_key
VITE_DEBUG_GEOAPIFY=false

# =========================
# OPENAI
# =========================
VITE_OPENAI_API_KEY=your_openai_api_key

# =========================
# CLOUDINARY
# =========================
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# =========================
# SUPABASE (RAG)
# =========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_ANON_KEY=your_anon_key

# =========================
# WEBHOOK / N8N
# =========================
WEBHOOK_PORT=3001
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your_webhook_secret
ALLOWED_ORIGINS=http://localhost:5173,https://sentinelph.web.app

# =========================
# TWILIO (SMS)
# =========================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# =========================
# EMAIL (NODEMAILER)
# =========================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
FRONTEND_URL=http://localhost:5173

# =========================
# MAYA SANDBOX (PAYMENTS)
# =========================

# Base URL (Sandbox)
MAYA_BASE_URL=https://pg-sandbox.paymaya.com

# Choose ONE sandbox merchant (recommended: Party 2)
MAYA_PUBLIC_KEY=maya_public_key
MAYA_SECRET_KEY=maya_secret_key

# Optional: Pay with Maya (QR / Wallet)
MAYA_PAYWITH_PUBLIC_KEY=maya_public_key
MAYA_PAYWITH_SECRET_KEY=maya_secret_key

# Webhook (important for payment status)
MAYA_WEBHOOK_URL=http://localhost:3001/api/maya/webhook

# Environment flag
MAYA_ENV=sandbox